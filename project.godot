; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="SpellForge Arena"
run/main_scene="res://Scenes/Core/Main.tscn"
config/features=PackedStringArray("4.8", "GL Compatibility")

[autoload]

SettingsManager="*res://Scripts/Core/settings_manager.gd"
CameraEffects="*res://Scripts/Core/camera_effects.gd"
MetaProgression="*res://Scripts/Meta/meta_progression.gd"
GameManager="*res://Scripts/Core/game_manager.gd"
InputManager="*res://Scripts/Core/input_manager.gd"
AudioManager="*res://Scripts/Core/audio_manager.gd"
VFXManager="*res://Scripts/Core/vfx_manager.gd"
SceneManager="*res://Scripts/Core/scene_manager.gd"
NetworkManager="*res://Scripts/Multiplayer/network_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

